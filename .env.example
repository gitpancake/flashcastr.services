# ===== Shared (all services) =====
RABBITMQ_URL=amqp://user:pass@localhost:5672
NODE_ENV=development
LOG_LEVEL=info
METRICS_PORT=9090

# ===== flash-engine =====
PROXY_LIST=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080
FALLBACK_PROXY_LIST=http://backup:8080
CRON_SCHEDULE=*/5 * * * *

# ===== image-engine =====
PINATA_JWT=eyJhbGc...
CONSUMER_CONCURRENCY=5
CONSUMER_RATE_LIMIT=250
# PROXY_LIST (shared with flash-engine)

# ===== database-engine =====
DATABASE_URL=postgresql://user:pass@localhost:5432/flashcastr
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_IDLE_TIMEOUT=30000
BATCH_SIZE=50
BATCH_FLUSH_INTERVAL_MS=5000

# ===== neynar-engine =====
# DATABASE_URL (shared with database-engine)
# DB_POOL_MAX=5 (lower for neynar-engine)
NEYNAR_API_KEY=your-neynar-api-key
SIGNER_ENCRYPTION_KEY=your-hex-encryption-key
RETRY_INTERVAL_MS=300000
